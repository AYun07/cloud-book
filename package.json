{
  "name": "cloud-book",
  "version": "1.0.0",
  "description": "☁️ AI驱动的下一代小说创作平台 - 面向全球的多语言智能写作系统",
  "private": false,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsc --watch -p packages/core/tsconfig.json",
    "build": "tsc -p packages/core/tsconfig.json",
    "build:all": "pnpm -r build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint packages/core/src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf packages/*/dist",
    "prepare": "pnpm build"
  },
  "keywords": [
    "novel",
    "writing",
    "ai",
    "creative-writing",
    "story-generation",
    "fiction",
    "webnovel",
    "writing-assistant",
    "ai-writing",
    "multi-language"
  ],
  "author": "Cloud Book Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/cloud-book/cloud-book"
  },
  "bugs": {
    "url": "https://github.com/cloud-book/cloud-book/issues"
  }
}
