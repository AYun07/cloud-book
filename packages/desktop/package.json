{
  "name": "@cloud-book/desktop",
  "version": "1.0.0",
  "description": "Cloud Book Desktop - Electron桌面应用",
  "main": "dist/main.js",
  "scripts": {
    "dev": "electron .",
    "build": "tsc && electron-builder",
    "build:win": "tsc && electron-builder --win",
    "build:mac": "tsc && electron-builder --mac",
    "build:linux": "tsc && electron-builder --linux"
  },
  "build": {
    "appId": "com.cloudbook.app",
    "productName": "Cloud Book",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "../web/dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.4.0"
  }
}
